AUTH_TOKEN_SIGNING_SECRET=replace-with-at-least-32-character-secret
AUTH_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=1209600
AUTH_REFRESH_COOKIE_NAME=lovv_session
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/
AUTH_ISSUER=lovv-auth
AUTH_AUDIENCE=lovv-api
CORS_ALLOW_ORIGINS=http://localhost:5173

GOOGLE_CLIENT_ID=replace-with-google-web-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-web-client-secret
KAKAO_CLIENT_ID=replace-with-kakao-oidc-client-id
KAKAO_CLIENT_SECRET=replace-with-kakao-client-secret-if-enabled

DB_ACCESS_MODE=mysql
RDS_HOST=replace-with-existing-lovv-data-stack-rds-host
RDS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:replace-me
RDS_DATABASE_NAME=lovvdev
USERS_TABLE_NAME=users
SOCIAL_ACCOUNTS_TABLE_NAME=social_accounts
PREFERENCES_TABLE_NAME=user_preferences
SAVED_PLANS_TABLE_NAME=saved_plans

AUTH_SESSIONS_TABLE_NAME=lovv_dev_auth_sessions
